      "Bash(sed 's/\\\\x1b\\\\[[0-9;]*[a-zA-Z]//g; s/\\\\x1b[A//g; s/\\\\x1b\\\\[?.*[a-zA-Z]//g')",
      "Read(//tmp/**)",
      "Bash(openssl s_client -connect helloai.com:443 -tls1_2)",
      "Bash(openssl s_client -connect helloai.com:443 -tls1_3)",
      "Bash(nmap --script ssl-enum-ciphers -p 443 helloai.com)",
